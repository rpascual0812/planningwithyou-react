# Production: absolute API origin (e.g. https://api.planningwithyou.com)
# Development: point at Django (CORS allows http://localhost:5173)
VITE_API_BASE_URL=http://localhost:8000
VITE_DEV_API_PROXY_TARGET=http://localhost:8000
VITE_JWT_LOGIN_PATH=/token/
# VITE_JWT_REFRESH_PATH=/token/refresh/
# SimpleJWT token blacklist (persists revoked refresh in DB). Leave unset for default `/token/blacklist/`.
# VITE_JWT_LOGOUT_PATH=/token/blacklist/

# npm run build -- --mode live