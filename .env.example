# Leave VITE_API_BASE_URL empty in development so requests go through the Vite
# dev proxy at /api/*. The proxy forwards to VITE_DEV_API_PROXY_TARGET (see
# vite.config.ts), which defaults to http://localhost:8000.
#
# Set VITE_API_BASE_URL to your absolute backend URL in production builds.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:8000
VITE_JWT_LOGIN_PATH=/api/token/
# Optional: SimpleJWT refresh (default `/api/token/refresh/`).
# VITE_JWT_REFRESH_PATH=/api/token/refresh/
# Optional: REST user list (default `/api/users`).
# VITE_API_USERS_PATH=/api/users
# SimpleJWT token blacklist (persists revoked refresh in DB). Leave unset for default `/api/token/blacklist/`.
# VITE_JWT_LOGOUT_PATH=/api/token/blacklist/
